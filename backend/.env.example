# Copy this file to .env and fill in real values. Never commit .env to git.

# Google Gemini API key - get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Secret used to sign JWT auth tokens - generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_long_random_secret

# SQLite database file (relative to backend/ folder)
DATABASE_URL=sqlite:///./debt_relief.db

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
